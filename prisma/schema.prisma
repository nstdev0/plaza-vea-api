generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  skuId       String   @id
  name        String
  searchName  String
  price       BigInt
  imageUrl    String?
  brand       String?
  category    String[]
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  supermarket String
}
